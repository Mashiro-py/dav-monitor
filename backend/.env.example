# 复制为 .env 后按需修改。切勿把真实密钥提交到仓库。
# 数据库：开发用 SQLite，生产可换 MySQL，例如 mysql+pymysql://user:pass@host/db
DB_URL=sqlite:///./data.db

# /ingest 共享密钥（可选）。设置后，插件 / webhook 调用需带 X-Ingest-Token 头。留空则不校验。
INGEST_TOKEN=

# 允许的前端跨域来源，逗号分隔；* 表示全部（开发用）
CORS_ORIGINS=*

# 可选：AI 分析（Step 7）。留空则不跑分析，前端显示占位。
ANTHROPIC_API_KEY=
ANALYZE_MODEL=claude-haiku-4-5-20251001
