# 复制为 deploy/.env（被 gitignore 排除，不会进仓库）。全部可选——不建也能跑。
# backend-compose.yml 会读取这里的变量。

# /ingest（插件微博/X，走公网）的校验密钥。设了之后，插件要在「设置 → Ingest Token」填同样的值。
# 留空 = 不校验。
INGEST_TOKEN=

# /ingest/wemp（公众号 webhook，同机内网）的独立密钥，与 INGEST_TOKEN 互不影响。
# 留空 = 不校验（保持现有免 token 的公众号链路）。除非你也想保护它，否则不用填。
WEMP_TOKEN=

# 前端跨域来源，逗号分隔；* = 放开（开发/内网）。生产可填前端域名。
CORS_ORIGINS=*
